{
    "name": "@tootega/dase-mcp",
    "version": "1.0.666",
    "description": "MCP server for the DASE ORM Designer - embedded server library (consumed by the DASE VS Code extension) plus a standalone stdio proxy publishable as a Claude Code plugin.",
    "author": "Hermes Silva <hxpelo@gmail.com>",
    "license": "MIT",
    "main": "dist/embedded/index.js",
    "types": "dist/embedded/index.d.ts",
    "bin": {
        "dase-mcp": "claude-plugin/server/dase-mcp.cjs"
    },
    "files": [
        "dist",
        "claude-plugin",
        "README.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.json && npm run bundle",
        "bundle": "esbuild src/proxy/index.ts --bundle --platform=node --format=cjs --outfile=claude-plugin/server/dase-mcp.cjs",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/node": "^20.14.0",
        "esbuild": "^0.24.0",
        "typescript": "^5.5.0"
    },
    "engines": {
        "node": ">=18"
    }
}
